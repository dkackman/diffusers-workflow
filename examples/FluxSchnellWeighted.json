{
    "variables": {
        "prompt": "a (photorealistic:1.4) portrait of a woman with (bright red hair:1.3) and [freckles], standing in a (misty:0.8) forest, (golden hour lighting:1.5), sharp focus"
    },
    "id": "FluxSchnellWeighted",
    "steps": [
        {
            "name": "txt2img",
            "pipeline": {
                "configuration": {
                    "component_type": "FluxPipeline",
                    "prompt_weighting": true
                },
                "from_pretrained_arguments": {
                    "model_name": "black-forest-labs/FLUX.1-schnell",
                    "torch_dtype": "torch.bfloat16"
                },
                "arguments": {
                    "prompt": "variable:prompt",
                    "num_inference_steps": 20,
                    "guidance_scale": 4.0,
                    "height": 1280,
                    "width": 896
                }
            },
            "result": {
                "content_type": "image/jpeg"
            }
        }
    ]
}